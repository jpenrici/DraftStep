#!/usr/bin/env julia
# =============================================================================
# bin/draftstep — DraftStep CLI Entrypoint
# =============================================================================
#
# Usage:
#   julia bin/draftstep <input.draftstep> [output.svg] [--quiet, --debug]
#
# Arguments:
#   input.draftstep   path to the source file (required)
#   output.svg        path for the SVG output  (optional)
#                     default: same name as input with .svg extension
# Options:
#   --quiet           does not show any logs
#   --debug           show processing with debug logs
#
# Examples:
#   julia bin/draftstep examples/hello.draftstep
#   julia bin/draftstep examples/hello.draftstep tmp/hello.svg
#   julia bin/draftstep examples/hello.draftstep tmp/hello.svg --quiet
#   julia bin/draftstep examples/hello.draftstep tmp/hello.svg --debug
#
# Exit codes:
#   0 — success
#   1 — usage error  (wrong number of arguments)
#   2 — file error   (input not found, output not writable)
#   3 — parse error  (LexerError or ParserError in the source file)
#   4 — runtime error (InterpreterError or RendererError)
# =============================================================================

# ---------------------------------------------------------------------------
# Locate src/ relative to this script — works regardless of working directory
# ---------------------------------------------------------------------------
const SCRIPT_DIR = dirname(abspath(@__FILE__))
const SRC_DIR    = joinpath(SCRIPT_DIR, "..", "src")

include(joinpath(SRC_DIR, "Logger.jl"))
import .Logger

include(joinpath(SRC_DIR, "Types.jl"))
import .Types

include(joinpath(SRC_DIR, "Lexer.jl"))
import .Lexer

include(joinpath(SRC_DIR, "Parser.jl"))
import .Parser

include(joinpath(SRC_DIR, "Interpreter.jl"))
import .Interpreter

include(joinpath(SRC_DIR, "Renderer.jl"))
import .Renderer

include(joinpath(SRC_DIR, "Renderers", "SVGRenderer.jl"))
import .SVGRenderer


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

function usage()
    println(stderr, """
    DraftStep — command-driven vector drawing tool

    Usage:
      julia bin/draftstep <input.draftstep> [output.svg] [--quiet, --debug]

    Arguments:
      input.draftstep   source file to interpret  (required)
      output.svg        SVG output path           (optional, default: <input>.svg)

    Options:
      --quiet           does not show any logs
      --debug           show processing with debug logs

    Examples:
      julia bin/draftstep examples/hello.draftstep
      julia bin/draftstep examples/hello.draftstep tmp/hello.svg
      julia bin/draftstep examples/hello.draftstep tmp/hello.svg --quiet
      julia bin/draftstep examples/hello.draftstep tmp/hello.svg --debug
    """)
end

"""
default_output(input_path) → String

Returns the default output path: same directory and stem, `.svg` extension.
"""
function default_output(input_path::String)::String
    dir  = dirname(input_path)
    stem = splitext(basename(input_path))[1]
    return joinpath(dir == "" ? "." : dir, stem * ".svg")
end


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

function main(args::Vector{String})

    # --- Configure ---
    local input_path = nothing
    local output_path = nothing
    local log_option = nothing

    Logger.enable!(Logger.LOG_INFO)

    # --- Argument validation ---
    if length(args) < 1 || length(args) > 3
        usage()
        exit(1)
    end

    # --- Check arguments ---
    for arg in args
        if endswith(lowercase(arg), ".draftstep")
            input_path = arg
        elseif endswith(lowercase(arg), ".svg")
            output_path = arg
        elseif startswith(arg, "--")
            log_option = lowercase(arg)
        end
    end

    # --- Paths ---
    if input_path == nothing
        usage()
        exit(1)
    end

    output_path = output_path !== nothing ? output_path : default_output(input_path)

    # --- Input file check ---
    if !isfile(input_path)
        println(stderr, "[ERROR] input file not found: '$input_path'")
        exit(2)
    end

    # --- Show Logs ---
    if log_option == "--quiet"
        Logger.disable!()
    elseif log_option == "--debug"
        Logger.enable!(Logger.LOG_DEBUG)
    elseif log_option !== nothing
        Logger.warn("unknown option '$log_option' — ignored")
    end

    Logger.info("input  : $input_path")
    Logger.info("output : $output_path")

    # --- Lexer ---
    local tokens
    try
        tokens = Lexer.tokenize_file(input_path)
        Logger.info("[1/4] tokenizing — $(length(tokens)) tokens")
    catch e
        Logger.error("[1/4] tokenizing — FAILED\n$(e)")
        exit(3)
    end

    # --- Parser ---
    local program
    try
        program = Parser.parse(tokens)
        Logger.info("[2/4] parsing — $(length(program.commands)) commands")
    catch e
        Logger.error("[2/4] parsing — FAILED\n$(e)")
        exit(3)
    end

    # --- Interpreter ---
    local state
    try
        state = Interpreter.execute(program)
        total = sum(
            length(l.shapes) + sum(length(g.shapes) for g in l.groups; init=0)
            for l in state.layers; init=0)
        Logger.info("[3/4] interpreting — $(length(state.layers)) layers, $total shapes")
    catch e
        Logger.error("[3/4] interpreting — FAILED\n$(e)")
        exit(4)
    end

    # --- Renderer ---
    try
        # Ensure output directory exists
        out_dir = dirname(output_path)
        if out_dir != "" && !isdir(out_dir)
            mkpath(out_dir)
        end
        SVGRenderer.render(state, output_path)
        size_kb = round(filesize(output_path) / 1024; digits=1)
        Logger.info("[4/4] rendering — $(size_kb) KB")
    catch e
        Logger.error("[4/4] rendering — FAILED\n$(e)")
        exit(4)
    end

    Logger.info("Done → $output_path")
end


if abspath(PROGRAM_FILE) == @__FILE__
    main(ARGS)
end
